# This .gitignore file should be placed at the root of your Unity project directory.

# Unity generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emory[Cc]aptures/
/[Rr]ecordings/
/.utmp/

# Unity generated files
*.tmp
*.temp
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
sysinfo.txt
*.stackdump

# Unity crash reports
*.crash
*.dmp
*.mdmp

# Unity addressables / streaming generated data
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Autogenerated JetBrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio / Rider / IDE files
.vscode/
.cursor/
.vs/
.idea/
*.csproj
*.sln
*.slnx
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Gradle cache and generated Android files
.gradle/
/[Aa]ssets/Plugins/Android/[Ll]ocal[Pp]roperties.asset
/[Aa]ssets/Plugins/Android/local.properties

# Build output
*.apk
*.aab
*.unitypackage
*.app

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Package/build caches
node_modules/
.cache/
artifacts/
